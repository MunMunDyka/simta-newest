# ===========================================
# SIMTA Backend - Environment Variables
# ===========================================
# Copy file ini ke .env dan isi dengan nilai yang sesuai

# Server Configuration
PORT=7860
NODE_ENV=development

# ===========================================
# MongoDB Atlas Configuration
# ===========================================
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/simta_db?retryWrites=true&w=majority

# ===========================================
# JWT Configuration
# ===========================================
# Access Token - digunakan untuk autentikasi request
JWT_SECRET=your_super_secret_jwt_key_here_min_32_characters
JWT_EXPIRES_IN=7d

# Refresh Token - untuk perpanjang access token
JWT_REFRESH_SECRET=your_refresh_secret_key_here_min_32_characters
JWT_REFRESH_EXPIRES_IN=30d

# ===========================================
# CORS Configuration
# ===========================================
# URL frontend yang diizinkan (pisahkan dengan koma untuk multiple origins)
FRONTEND_URL=http://localhost:5173

# ===========================================
# File Upload Configuration
# ===========================================
# Maksimal ukuran file dalam MB
MAX_FILE_SIZE=10
# Folder untuk menyimpan file upload
UPLOAD_DIR=uploads

# ===========================================
# Email Notification Configuration (Resend)
# ===========================================
# Enable/disable email notifications
EMAIL_ENABLED=false

# Provider awal: resend
EMAIL_PROVIDER=resend

# Buat API key di https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx

# Gunakan domain yang sudah diverifikasi di Resend untuk production
# Contoh: SIMTA <noreply@simta.domainkamu.com>
EMAIL_FROM="SIMTA <noreply@yourdomain.com>"

# URL aplikasi yang dipakai di tombol/link email
APP_URL=https://simta-iteba-demo.netlify.app/

# ===========================================
# WhatsApp Notification Configuration
# ===========================================
# Enable/disable WhatsApp notifications
WHATSAPP_ENABLED=false

# Provider: fonnte | meta
WHATSAPP_PROVIDER=fonnte

# Fonnte Configuration (fonnte.com)
# - Daftar di fonnte.com
# - Scan QR WhatsApp
# - Copy token dari dashboard
WHATSAPP_API_TOKEN=your_fonnte_token_here
