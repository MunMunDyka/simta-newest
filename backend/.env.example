# ===========================================
# SIMTA Backend - Environment Variables
# ===========================================
# Copy file ini ke .env dan isi dengan nilai yang sesuai

# Server Configuration
PORT=7860
NODE_ENV=development

# ===========================================
# MongoDB Atlas Configuration
# ===========================================
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/simta_db?retryWrites=true&w=majority

# ===========================================
# JWT Configuration
# ===========================================
# Access Token - digunakan untuk autentikasi request
JWT_SECRET=your_super_secret_jwt_key_here_min_32_characters
JWT_EXPIRES_IN=7d

# Refresh Token - untuk perpanjang access token
JWT_REFRESH_SECRET=your_refresh_secret_key_here_min_32_characters
JWT_REFRESH_EXPIRES_IN=30d

# ===========================================
# CORS Configuration
# ===========================================
# URL frontend yang diizinkan (pisahkan dengan koma untuk multiple origins)
FRONTEND_URL=http://localhost:5173

# ===========================================
# File Upload Configuration
# ===========================================
# Maksimal ukuran file dalam MB
MAX_FILE_SIZE=10
# Folder untuk menyimpan file upload
UPLOAD_DIR=uploads

# ===========================================
# Email Notification Configuration
# ===========================================
# Enable/disable email notifications (true/false)
EMAIL_ENABLED=false

# Provider: smtp | gmail_api | resend
EMAIL_PROVIDER=smtp

# Gmail API tanpa domain, cocok untuk Hugging Face karena lewat HTTPS/443:
# 1. Buat Google Cloud OAuth Client
# 2. Enable Gmail API
# 3. Ambil refresh token dengan scope https://www.googleapis.com/auth/gmail.send
GMAIL_CLIENT_ID=your_google_oauth_client_id
GMAIL_CLIENT_SECRET=your_google_oauth_client_secret
GMAIL_REFRESH_TOKEN=your_google_oauth_refresh_token
GMAIL_USER_ID=me
EMAIL_FROM="SIMTA <simta.demo@gmail.com>"

# SMTP Gmail tanpa domain:
# 1. Buat Gmail khusus untuk SIMTA
# 2. Aktifkan 2-Step Verification
# 3. Buat App Password, lalu isi SMTP_PASS dengan app password itu
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
# Untuk Hugging Face: paksa IPv4 dan coba fallback 587 jika 465 gagal
SMTP_FORCE_IPV4=true
SMTP_FALLBACK_PORTS=465,587
SMTP_USER=simta.demo@gmail.com
SMTP_PASS=your_16_digit_app_password

# Resend opsional, butuh domain verified untuk kirim ke email selain akun sendiri
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx

# URL aplikasi yang dipakai di tombol/link email
APP_URL=https://simta-iteba-demo.netlify.app/

# ===========================================
# WhatsApp Notification Configuration
# ===========================================
# Enable/disable WhatsApp notifications
WHATSAPP_ENABLED=false

# Provider: fonnte | meta
WHATSAPP_PROVIDER=fonnte

# Fonnte Configuration (fonnte.com)
# - Daftar di fonnte.com
# - Scan QR WhatsApp
# - Copy token dari dashboard
WHATSAPP_API_TOKEN=your_fonnte_token_here
